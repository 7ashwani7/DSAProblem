class Solution {
public:
    int minimumTotal(vector<vector<int>>& t) {
        int n = t.size();
        for(int i=n-2;i>=0;i--){
            int m = t[i].size();
            for(int j=0;j<m;j++){
                t[i][j] += min(t[i+1][j], t[i+1][j+1]);
            }
        }
        return t[0][0];
    }
};